# weather-trader local backend configuration
# Copy to .env for local development. Never commit real secrets.

# Local API bind settings.
WEATHER_TRADER_HOST=127.0.0.1
WEATHER_TRADER_PORT=8787

# Runtime mode. live is intentionally unsupported in this initial package.
WEATHER_TRADER_MODE=paper

# Local SQLite database path for future paper-trading state.
WEATHER_TRADER_DB_PATH=./data/weather-trader.sqlite

# Logging: debug, info, warn, or error.
WEATHER_TRADER_LOG_LEVEL=info

# Public Polymarket market-data endpoints. These do not require credentials.
POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com
WEATHER_TRADER_DISCOVERY_LIMIT=100
WEATHER_TRADER_REQUEST_TIMEOUT_MS=10000

# Public weather data endpoints. NWS requires an identifying User-Agent.
NWS_BASE_URL=https://api.weather.gov
NWS_USER_AGENT=weather-trader/0.1.0 (local paper-mode research; contact: operator@example.com)
OPEN_METEO_BASE_URL=https://api.open-meteo.com


# Locked live-trading skeleton. Leave disabled unless intentionally running a reviewed local live process.
LIVE_TRADING_ENABLED=false
LIVE_TRADING_KILL_SWITCH=true
# Required only when WEATHER_TRADER_MODE=live and LIVE_TRADING_ENABLED=true. Do not put these in browser files.
POLYMARKET_CLOB_API_KEY=
POLYMARKET_CLOB_API_SECRET=
POLYMARKET_CLOB_API_PASSPHRASE=
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_SIGNATURE_TYPE=
