ballzatram.com {
  encode zstd gzip

  # Match the app upload limit so large rights-approved source files can reach FastAPI.
  request_body {
    max_size 750MB
  }

  root * /srv/ballzatram

  @api path /api/*
  handle @api {
    reverse_proxy api:8000 {
      transport http {
        dial_timeout 30s
        response_header_timeout 300s
        read_timeout 1h
        write_timeout 1h
      }
    }
  }

  @media path /media/*
  handle @media {
    reverse_proxy api:8000 {
      transport http {
        dial_timeout 30s
        response_header_timeout 300s
        read_timeout 1h
        write_timeout 1h
      }
    }
  }

  @aiEdit path /ai-edit-factory /ai-edit-factory/*
  handle @aiEdit {
    reverse_proxy api:8000 {
      transport http {
        dial_timeout 30s
        response_header_timeout 300s
        read_timeout 1h
        write_timeout 1h
      }
    }
  }

  handle {
    file_server
  }
}
